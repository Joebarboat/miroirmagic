# =============================================================================
# 🚀 .htaccess optimisé — miroirmagic.fr
# Stack: Laravel/Statamic + Cloudflare + Apache 2.4+
# Dernière mise à jour: 2026
# =============================================================================

# ----------------------------------------
# 🛡️ SÉCURITÉ & HEADERS (Défense en profondeur)
# ----------------------------------------
<IfModule mod_headers.c>
    # 🔥 Cache long pour assets statiques (Cloudflare + navigateur)
    <FilesMatch "\.(ico|jpe?g|png|gif|webp|svg|woff2?|ttf|css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # 🔄 Cache court pour contenu dynamique
    <FilesMatch "\.(html|php|json|xml)$">
        Header set Cache-Control "public, max-age=600, must-revalidate"
    </FilesMatch>

    # 🔒 Headers de sécurité modernes
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # 🚀 HSTS — Activer progressivement :
    # Étape 1 (test) : max-age=300
    # Étape 2 (prod) : max-age=31536000; includeSubDomains
    # Étape 3 (preload) : + preload (après soumission hstspreload.org)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# 🚫 Désactivation ETag (évite conflits de cache avec CDN)
FileETag None
<IfModule mod_headers.c>
    Header unset ETag
</IfModule>


# =============================================================================
# 🔄 RÉÉCRITURE & ROUTAGE (Cloudflare-safe)
# =============================================================================
<IfModule mod_rewrite.c>
    Options -MultiViews -Indexes
    RewriteEngine On

    # 🔐 Force HTTPS — Logique robuste : Cloudflare + serveur direct
    # Priorité : CF-Visitor > X-Forwarded-Proto > HTTPS natif
    RewriteCond %{HTTP:CF-Visitor} !'"scheme":"https"' [NC]
    RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 🌐 Redirection www → non-www (SEO propre, après HTTPS)
    RewriteCond %{HTTP_HOST} ^www\. [NC]
    RewriteRule ^(.*)$ https://miroirmagic.fr/$1 [L,R=301]

    # 🔑 Gestion headers d'authentification (Laravel / Statamic)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # ✂️ Suppression des slashes de fin (si ce n'est pas un dossier)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # 🔗 Redirections SEO spécifiques (à enrichir selon vos besoins)
    RewriteRule ^photobooth-cannes/?$ /photobooth/cannes [L,R=301]
    RewriteRule ^contact/?$ /contacter [L,R=301]
    RewriteRule ^wp-content/uploads/2023/05/Location-Photobooth-entreprise-Cannes\.jpg$ /images/Location-Photobooth-entreprise-Cannes.webp [L,R=301]

    # 🖼️ Fallback WebP intelligent (si navigateur compatible + fichier existe)
    RewriteCond %{HTTP_ACCEPT} image/webp
    RewriteCond %{REQUEST_FILENAME}\.webp -f
    RewriteRule (.+)\.(jpe?g|png)$ $1.$2.webp [T=image/webp,E=accept:1]

    # 🎯 Front controller (Statamic / Laravel) — Dernière règle !
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>


# =============================================================================
# 📦 COMPRESSION (fallback si Cloudflare désactivé ou test local)
# =============================================================================
# 💡 Cloudflare gère déjà Brotli/Gzip au edge.
# Ces règles servent uniquement en environnement hors-Cloudflare.
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json application/xml
</IfModule>

<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css application/javascript application/json application/xml
</IfModule>

# =============================================================================
# 📦 Performances
# =============================================================================

<IfModule mod_expires.c>
    ExpiresActive On

    # Images
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"

    # CSS / JS
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"

    # Fonts
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|png|jpg|jpeg|webp|svg|woff2?)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
