                            <!-- Image -->
                            <div
                                class="fbox-img !mb-0 gr--whitesmoke h--195 xl:!m-[0_8px_30px] xl:!pt-[42px] lg:max-xl:!mt-0 lg:max-xl:!mb-[20px] lg:max-xl:mx-0 lg:max-xl:pt-[35px] md:max-lg:!mt-0 md:max-lg:!mb-[20px] md:max-lg:mx-0 md:max-lg:pt-[30px] sm:max-md:!mt-0 sm:max-md:!mb-[20px] sm:max-md:mx-[10%] sm:max-md:pt-[46px] xsm:max-sm:!mt-0 xsm:max-sm:!mb-[20px] xsm:max-sm:mx-3 xsm:max-sm:pt-[40px] rounded-[12px_12px_0_0]">
