    {{ quote_section }}
    <section
        class="py--50 py-[50px] lg:max-xl:py-[60px] md:max-lg:py-[60px] after:absolute after:content-[''] after:z-[-1] after:w-[150%] after:!h-3/4 after:-left-1/4 after:!top-0 xsm:max-sm:after:!h-[92%] shape--gr-whitesmoke reviews-section">
        <div class="container">
            <!-- TESTIMONIALS CONTENT -->
            <div class="flex flex-wrap mx-[calc(-0.5*_1.5rem)]">
                <div class="flex-none w-full max-w-full px-[calc(0.5*_1.5rem)] justify-center">
                    <!-- TESTIMONIAL #1 -->
                    <div
                        class="review-1 author-box block-shadow rounded-xl pt-[40px] !pb-[30px] px-[40px] lg:max-xl:pt-[35px] lg:max-xl:!pb-[25px] lg:max-xl:px-[25px] sm:max-md:pt-[35px] sm:max-md:!pb-[30px] sm:max-md:px-8 xsm:max-sm:!mt-0 xsm:max-sm:!mb-[20px] xsm:max-sm:mx-[6px] xsm:max-sm:pt-[35px] xsm:max-sm:!pb-[30px] xsm:max-sm:px-[20px] md:max-lg:pt-[35px] md:max-lg:!pb-[25px] md:max-lg:px-[25px] shadow-[0_4px_12px_0_rgba(0,0,0,0.08)]">
                        <!-- Quote Icon -->
                        <div class="review-ico ico-65 relative mt-[-25px] opacity-10 -ml-[10px]">
                            <span class="flaticon-quote"></span>
                        </div>
                        <!-- Text -->
                        <div
                            class="review-txt relative mt-[-45px] lg:max-xl:!mt-[-42px] md:max-lg:!mt-[-38px] sm:max-md:!mt-[-43px] xsm:max-sm:-mt-[40px]">
                            <!-- Text -->
                            <p class="leading-[1.6] !text-[1.25rem]">
                                {{ text }}
                            </p>
                            <!-- Author -->
                            <div
                                class="author-data clearfix mt-[22px] lg:max-xl:!mt-[15px] md:max-lg:!mt-0 sm:max-md:!mt-[20px] xsm:max-sm:!mt-[20px]">
                                <!-- Avatar -->
                                <div class="review-avatar float-left !m-[0_auto]">
                                    {{ author_image }}
                                    <img class="!w-[64px] !h-[64px] rounded-[100%] lg:max-xl:!w-[54px] lg:max-xl:!h-[54px] md:max-lg:!w-[50px] md:max-lg:!h-[50px] sm:max-md:!w-[52px] sm:max-md:!h-[52px] xsm:max-sm:!w-[52px] xsm:max-sm:!h-[52px]"
                                        src="{{ url }}" alt="{{ alt }}" loading="lazy" />
                                    {{ /author_image }}
                                </div>
                                <!-- Data -->
                                <div
                                    class="review-author !mt-1 md:max-lg:!mt-[3px] sm:max-md:!mt-[3px] xsm:max-sm:!mt-[3px] relative inline-block !text-left p-[0_0_0_15px] lg:max-xl:!pl-[12px] lg:max-xl:pr-0 lg:max-xl:py-0 md:max-lg:!pl-[12px] md:max-lg:pr-0 md:max-lg:py-0 sm:max-md:!pl-[12px] sm:max-md:pr-0 sm:max-md:py-0 xsm:max-sm:!pl-[12px] xsm:max-sm:pr-0 xsm:max-sm:py-0">
                                    <div
                                        class="s-18 w--700 xl:!text-[0.975rem] lg:max-xl:!text-[1rem] md:max-lg:!text-[1rem] sm:max-md:!text-[1.25rem] xsm:max-sm:!text-[1.2rem] !font-bold leading-none xl:!mb-[8px] lg:max-xl:!mb-[8px] md:max-lg:!mb-[5px] sm:max-md:!mb-[8px] xsm:max-sm:!mb-[8px] font-Jakarta">
                                        {{ author_name }}
                                    </div>
                                    <p class="p-sm leading-none !font-light !mb-0">
                                        {{ author_position }}
                                    </p>
                                </div>
                            </div>
                            <!-- End Author -->
                        </div>
                        <!-- End Text -->
                    </div>
                    <!-- END TESTIMONIAL #1 -->
                </div>
            </div>

            <!-- END TESTIMONIALS CONTENT -->
        </div>
        <!-- End container -->
    </section>
    {{ /quote_section }}

    {{ google_reviews_config }}
    <section id="google-reviews" class="py--100 py-[100px] lg:max-xl:py-[80px] md:max-lg:py-[70px] division bg-white">
        <div class="container">
            <!-- SECTION TITLE -->
            <div class="flex flex-wrap mx-[calc(-0.5*_1.5rem)] justify-center">
                <div class="md:w-10/12 lg:max-xl:w-9/12 xl:w-9/12 w-full flex-none px-[calc(0.5*_1.5rem)] max-w-full">
                    <div
                        class="section-title mb--50 xl:!mb-[50px] lg:max-xl:!mb-[40px] md:max-lg:!mb-[30px] !text-center">
                        <h2
                            class="s-50 w--700 xl:!text-[3.125rem] lg:max-xl:!text-[2.875rem] md:max-lg:!text-[2.64705rem] sm:max-md:!text-[2.375rem] xsm:max-sm:!text-[2.0625rem] !font-bold !tracking-[-0.5px] leading-[1.25] font-Jakarta sm:max-md:!leading-[1.35] xsm:max-sm:!leading-[1.35]">
                            {{ headline }}
                        </h2>
                        <div class="flex justify-center mt-4">
                            <span class="text-2xl mm-text-gold--soft font-bold">★★★★★</span>
                            <span class="ml-2 color--black self-center font-medium font-Jakarta">Sur Google</span>
                        </div>
                        <!-- Description with forced link styling -->
                        <div class="mt-8 color--grey max-w-2xl mx-auto s-21 font-medium review-description">
                            {{ description }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Custom Styles -->
            <style>
                .review-avatar {
                    width: 64px !important;
                    height: 64px !important;
                    min-width: 64px !important;
                    min-height: 64px !important;
                    border-radius: 50% !important;
                    object-fit: cover !important;
                }

                .review-description a {
                    color: #000000 !important;
                    text-decoration: underline !important;
                    font-weight: 600;
                }

                /* Custom Carousel Navigation */
                .custom-owl-prev,
                .custom-owl-next {
                    position: absolute;
                    top: 50%;
                    transform: translateY(-50%);
                    width: 44px;
                    height: 44px;
                    background: white;
                    border-radius: 50%;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
                    cursor: pointer;
                    z-index: 20;
                    transition: all 0.3s ease;
                    color: #333;
                }

                .custom-owl-prev:hover,
                .custom-owl-next:hover {
                    background: #222;
                    color: white;
                }

                .custom-owl-prev {
                    left: -20px;
                }

                .custom-owl-next {
                    right: -20px;
                }

                @media (max-width: 768px) {
                    .custom-owl-prev {
                        left: 0;
                    }

                    .custom-owl-next {
                        right: 0;
                    }
                }

                .mm-text-gold--soft {
                    color: #c8a257 !important;
                    background: linear-gradient(180deg,
                            #e2d3a7 0%,
                            #c8a257 60%,
                            #b08a2e 100%) !important;
                    -webkit-background-clip: text !important;
                    -webkit-text-fill-color: transparent !important;
                    display: inline-block;
                }

                /* Modal Review Styles */
                #review-modal {
                    display: none;
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    background: rgba(0, 0, 0, 0.6);
                    z-index: 99999;
                    align-items: center;
                    justify-content: center;
                    padding: 20px;
                    opacity: 0;
                    transition: opacity 0.3s ease;
                }

                #review-modal.active {
                    opacity: 1;
                }

                .review-modal-content {
                    background: white;
                    border-radius: 16px;
                    max-width: 600px;
                    width: 100%;
                    max-height: 90vh;
                    overflow-y: auto;
                    position: relative;
                    transform: scale(0.95);
                    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
                }

                #review-modal.active .review-modal-content {
                    transform: scale(1);
                }
            </style>

            <!-- REVIEWS GRID -->
            <div id="reviews-container-wrapper" class="w-full relative px-4 sm:px-6">
                <!-- Loading State -->
                <div id="reviews-loading" class="w-full text-center py-10">
                    <span class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-gray-900"></span>
                    <p class="mt-2 text-gray-500">Chargement des avis...</p>
                </div>

                <!-- Custom Navigation Arrows -->
                <div class="custom-owl-nav hidden md:block">
                    <div class="custom-owl-prev"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                            stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="15 18 9 12 15 6"></polyline>
                        </svg></div>
                    <div class="custom-owl-next"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                            stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"></polyline>
                        </svg></div>
                </div>

                <!-- Carousel Container (Hidden initially) -->
                <div class="owl-carousel reviews-carousel owl-theme opacity-0 transition-opacity duration-300"></div>
            </div>

            <div id="map-service-helper"></div>
        </div>

        <!-- (Review Modal moved to bottom of file) -->

        <script>
            // Store reviews globally for modal access
            window.googleReviewsData = [];

            function initGoogleReviews() {
                const mapHelper = document.getElementById('map-service-helper');
                const service = new google.maps.places.PlacesService(mapHelper);

                const request = {
                    placeId: '{{ google_place_id }}',
                    fields: ['name', 'rating', 'reviews', 'user_ratings_total']
                };

                service.getDetails(request, (place, status) => {
                    const loading = document.getElementById('reviews-loading');
                    const carouselContainer = document.querySelector('.reviews-carousel');

                    if (status === google.maps.places.PlacesServiceStatus.OK && place.reviews) {
                        // Sort by time (latest first)
                        // Normalize dates and text size
                        const reviews = place.reviews.sort((a, b) => b.time - a.time).slice(0, 10); // increased limit for carousel
                        window.googleReviewsData = reviews;

                        reviews.forEach((review, index) => {
                            const stars = '★'.repeat(Math.round(review.rating)) + '☆'.repeat(5 - Math.round(review.rating));
                            const profilePhoto = review.profile_photo_url || '/images/no_image_placeholder.png';

                            // Date Formatting (French, Month Year)
                            const dateObj = new Date(review.time * 1000);
                            const formattedDate = dateObj.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' });
                            // Capitalize first letter of month
                            const finalDate = formattedDate.charAt(0).toUpperCase() + formattedDate.slice(1);

                            // Truncate text logic
                            const maxChars = 140;
                            const isLongText = review.text.length > maxChars;
                            const shortText = isLongText ? review.text.substring(0, maxChars) + '...' : review.text;

                            // Inline Google SVG
                            const googleLogo = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="24px" height="24px"><path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"/><path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/><path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"/><path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"/></svg>`;

                            const html = `
                                <div class="item px-2 h-full py-4">
                                    <div class="review-card bg-white p-6 rounded-[12px] shadow-[0_5px_15px_rgba(0,0,0,0.08)] h-full flex flex-col hover:-translate-y-1 transition-transform duration-300 min-h-[360px] border border-gray-100 relative group cursor-pointer" onclick="openReviewModal(${index})">
                                        
                                        <!-- Header: Avatar & Name -->
                                        <div class="flex items-center mb-4">
                                            <img src="${profilePhoto}" 
                                                 alt="${review.author_name}" 
                                                 class="review-avatar rounded-full mr-3 object-cover border border-gray-100 shadow-sm" 
                                                 style="width: 64px; height: 64px;"
                                                 loading="lazy"
                                                 onerror="this.onerror=null;this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(review.author_name)}&background=random&color=fff&size=128';">
                                            <div>
                                                <h4 class="font-bold text-[1rem] font-Jakarta text-gray-800 leading-tight">${review.author_name}</h4>
                                                <p class="text-[0.65rem] text-gray-400 font-medium mt-1">${finalDate}</p>
                                            </div>
                                        </div>

                                        <!-- Stars -->
                                        <div class="mb-3 text-lg tracking-wide mm-text-gold--soft font-bold">${stars}</div>
                                        
                                        <!-- Review Text -->
                                        <div class="flex-grow">
                                            <p class="text-gray-600 leading-[1.6] text-[0.92rem] font-light">
                                                "${shortText}"
                                            </p>
                                            ${isLongText ? `
                                            <span class="text-xs text-theme underline mt-2 font-medium inline-block">
                                                Lire la suite
                                            </span>` : ''}
                                        </div>

                                        <!-- Footer Action -->
                                        <div class="mt-auto pt-4 border-t border-gray-50 flex justify-between items-center">
                                            <div class="flex items-center gap-2">
                                                 <div class="w-5 h-5">${googleLogo}</div>
                                                 <span class="text-[0.65rem] font-bold text-gray-400 uppercase tracking-wider">Avis Google</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            `;
                            $(carouselContainer).append(html);
                        });

                        // CSS Fix for Equal Heights in Owl Carousel
                        const style = document.createElement('style');
                        style.innerHTML = `
                            .reviews-carousel .owl-stage { display: flex; align-items: stretch; }
                            .reviews-carousel .owl-item { display: flex; height: auto; }
                            .reviews-carousel .item { width: 100%; }
                        `;
                        document.head.appendChild(style);

                        // Hide loading, show carousel
                        loading.style.display = 'none';
                        carouselContainer.classList.remove('opacity-0');

                        // Initialize Owl Carousel
                        var owl = $('.reviews-carousel');
                        owl.owlCarousel({
                            loop: true,
                            margin: 20,
                            nav: false, // Using custom arrows
                            dots: true,
                            autoplay: true,
                            autoplayTimeout: 6000,
                            autoplayHoverPause: true,
                            smartSpeed: 500,
                            responsive: {
                                0: { items: 1, margin: 10 },
                                768: { items: 2, margin: 15 },
                                1024: { items: 3, margin: 20 }
                            }
                        });

                        // Custom Navigation Events
                        $('.custom-owl-next').click(function () {
                            owl.trigger('next.owl.carousel');
                        });
                        $('.custom-owl-prev').click(function () {
                            owl.trigger('prev.owl.carousel');
                        });


                    } else {
                        console.error('Google Places API Error:', status);
                        loading.innerHTML = '<div class="text-red-500">Impossible de charger les avis pour le moment.</div>';
                    }
                });
            }

            function openReviewModal(index) {
                const review = window.googleReviewsData[index];
                if (!review) return;

                const modal = document.getElementById('review-modal');
                const modalBody = document.getElementById('review-modal-body');
                const stars = '★'.repeat(Math.round(review.rating)) + '☆'.repeat(5 - Math.round(review.rating));

                // Date Formatting
                const dateObj = new Date(review.time * 1000);
                const formattedDate = dateObj.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' });
                const finalDate = formattedDate.charAt(0).toUpperCase() + formattedDate.slice(1);

                const profilePhoto = review.profile_photo_url || '/images/no_image_placeholder.png';
                // Google Logo - Responsive SVG
                const googleLogo = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="w-full h-full"><path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"/><path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/><path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"/><path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571c0.001-0.001,0.002-0.001,0.003-0.002l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"/></svg>`;

                console.log('Opening Review Modal for index:', index, review);

                modalBody.innerHTML = `
                    <div class="flex items-start mb-4">
                        <div class="relative">
                            <img src="${profilePhoto}" 
                                class="review-avatar rounded-full mr-4 object-cover border border-gray-100 shadow-sm" 
                                style="width: 50px; height: 50px;"
                                onerror="this.onerror=null;this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(review.author_name)}&background=random&color=fff&size=128';">
                            
                        </div>
                        <div class="flex-1">
                            <h3 class="font-bold text-[1.1rem] font-Jakarta text-gray-900 leading-tight flex items-center gap-1">
                                ${review.author_name} 
                                <svg class="w-4 h-4 text-blue-500 fill-current" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                            </h3>
                            <p class="text-[0.8rem] text-gray-500 font-normal mt-0.5">${review.relative_time_description || finalDate}</p>
                        </div>
                    </div>

                    <div class="mb-4 text-lg tracking-wide mm-text-gold--soft font-bold">${stars}</div>
                    
                    ${review.text ? `
                    <div class="text-gray-800 font-normal text-[0.95rem] leading-[1.6] max-h-[50vh] overflow-y-auto pr-2 custom-scrollbar mt-4">
                        ${review.text}
                    </div>` : '<p class="text-gray-400 italic text-sm mt-4">Pas de commentaire écrit pour cet avis.</p>'}

                     <div class="mt-6 flex justify-between items-center bg-white border-t border-gray-100 pt-4">
                         <div class="flex items-center gap-2">
                             <div class="w-5 h-5 shrink-0">${googleLogo}</div>
                             <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Avis Google</span>
                         </div>
                         <a href="${review.author_url}" target="_blank" class="text-xs font-bold text-theme hover:underline uppercase tracking-wide">Voir sur Google</a>
                    </div>
                `;

                modal.style.display = 'flex';
                // Trigger reflow
                modal.offsetHeight;
                modal.classList.add('active');
                document.body.style.overflow = 'hidden'; // Prevent background scrolling
            }

            function closeReviewModal() {
                const modal = document.getElementById('review-modal');
                modal.classList.remove('active');
                setTimeout(() => {
                    modal.style.display = 'none';
                    document.body.style.overflow = '';
                }, 300);
            }

            // Close on background click
            const reviewModal = document.getElementById('review-modal');
            if (reviewModal) {
                reviewModal.addEventListener('click', function (e) {
                    if (e.target === this) {
                        closeReviewModal();
                    }
                });
            }

            // Close on escape key
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeReviewModal();
            });
        </script>
        <!-- Load Google Maps API with Async/Defer and Callback -->
        <script
            src="https://maps.googleapis.com/maps/api/js?key={{ google_places_api_key }}&libraries=places&callback=initGoogleReviews"
            async defer></script>
    </section>
    {{ /google_reviews_config }}

    {{ google_reviews_section }}
    <section class="py--100 py-[100px] lg:max-xl:py-[80px] md:max-lg:py-[70px] reviews-section division">
        <div class="container">
            <!-- SECTION TITLE -->
            <div class="flex flex-wrap mx-[calc(-0.5*_1.5rem)] justify-center">
                <div class="md:w-10/12 lg:max-xl:w-9/12 xl:w-9/12 w-full flex-none px-[calc(0.5*_1.5rem)] max-w-full">
                    <div
                        class="section-title mb--50 xl:!mb-[50px] lg:max-xl:!mb-[40px] md:max-lg:!mb-[30px] !text-center">
                        <h2
                            class="s-50 w--700 xl:!text-[3.125rem] lg:max-xl:!text-[2.875rem] md:max-lg:!text-[2.64705rem] sm:max-md:!text-[2.375rem] xsm:max-sm:!text-[2.0625rem] !font-bold !tracking-[-0.5px] leading-[1.25] font-Jakarta sm:max-md:!leading-[1.35] xsm:max-sm:!leading-[1.35]">
                            {{ headline }}
                        </h2>
                    </div>
                </div>
            </div>

            <!-- REVIEWS WIDGET CONTAINER -->
            <div class="google-reviews-wrapper w-full flex justify-center">
                {{ embed_code }}
            </div>
        </div>
    </section>
    {{ /google_reviews_section }}

    <!-- Review Modal (Moved here to avoid Z-Index stacking issues) -->
    <div id="review-modal" role="dialog" aria-modal="true" style="z-index: 2147483647 !important;">
        <div class="review-modal-content p-8 relative">
            <button onclick="closeReviewModal()"
                class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full bg-gray-100 hover:bg-gray-200 transition-colors z-10">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
            <div id="review-modal-body">
                <!-- Dynamic Content -->
            </div>
        </div>
    </div>

    <section class="py-[80px] lg:max-xl:py-[80px] md:max-lg:py-[70px] blog-section division has-colored-bg">
        <div class="container">
            <div class="flex flex-wrap mx-[calc(-0.5*_1.5rem)] justify-center">
                <div class="md:w-10/12 lg:max-xl:w-9/12 xl:w-9/12 w-full flex-none px-[calc(0.5*_1.5rem)] max-w-full">
                    <div
                        class="section-title mb--30 xl:!mb-[30px] lg:max-xl:!mb-[30px] md:max-lg:!mb-[30px] !text-center">
                        <!-- Title -->
                        <h2
                            class="s-50 w--700 xl:!text-[3.125rem] lg:max-xl:!text-[2.875rem] md:max-lg:!text-[2.64705rem] sm:max-md:!text-[2.375rem] xsm:max-sm:!text-[2.0625rem] !font-bold !tracking-[-0.5px] leading-[1.25] font-Jakarta sm:max-md:!leading-[1.35] xsm:max-sm:!leading-[1.35]">
                            Réseaux Sociaux
                        </h2>
                    </div>
                </div>
            </div>

            <div class="instagram-feed">
                <div class="elfsight-app-ba02ccce-ea98-4b03-b1ef-930d26c6a60e" data-elfsight-app-lazy></div>
            </div>

            <div class="img-block-btn !text-center wow fadeInUp !mt-10">
                {{ cta }}
                <!-- Button -->
                <a href="/nous-contacter-devis-photoboth-borne-miroir"
                    class="btn !rounded-[4px] btn--theme hover--tra-black">Demande de devis</a>
                {{ /cta }}
            </div>
        </div>
    </section>

    <!-- DIVIDER LINE -->
    <hr
        class="divider w-full h-px bg-transparent bg-[linear-gradient(90deg,rgba(206,211,246,0)_0,#bbb_38%,#bbb_64%,rgba(206,211,246,0)_99%)] opacity-40 !m-0 ![border:none]" />

    <!-- BLOG-1
                     ============================================= -->

    {{ blog_section }}
    <section class="py--100 py-[100px] lg:max-xl:py-[80px] md:max-lg:py-[70px] blog-section division has-colored-bg">
        <div class="container">
            <!-- SECTION TITLE -->
            <div class="flex flex-wrap mx-[calc(-0.5*_1.5rem)] justify-center">
                <div class="md:w-10/12 lg:max-xl:w-9/12 xl:w-9/12 w-full flex-none px-[calc(0.5*_1.5rem)] max-w-full">
                    <div
                        class="section-title mb--70 xl:!mb-[70px] lg:max-xl:!mb-[60px] md:max-lg:!mb-[50px] !text-center">
                        <!-- Title -->
                        <h2
                            class="s-50 w--700 xl:!text-[3.125rem] lg:max-xl:!text-[2.875rem] md:max-lg:!text-[2.64705rem] sm:max-md:!text-[2.375rem] xsm:max-sm:!text-[2.0625rem] !font-bold !tracking-[-0.5px] leading-[1.25] font-Jakarta sm:max-md:!leading-[1.35] xsm:max-sm:!leading-[1.35]">
                            {{ headline }}
                        </h2>
                        <!-- Text -->
                        <p
                            class="s-21 color--grey xl:!text-[1.3125rem] xl:!mt-[18px] !mb-0 lg:max-xl:!mt-[15px] lg:max-xl:!text-[1.18755rem] md:max-lg:!text-[1.32352rem] md:max-lg:!mt-[12px] sm:max-md:!text-[1.21875rem] sm:max-md:!mt-[12px] xsm:max-sm:!text-[1.1875rem] xsm:max-sm:!mt-[12px] xsm:max-sm:px-[3%] xsm:max-sm:py-0">
                            {{ subtitle }}
                        </p>
                    </div>
                </div>
            </div>
            <div class="flex flex-wrap mx-[calc(-0.5*_1.5rem)] sm:max-md:!px-4 xsm:max-sm:!px-2">
                {{ collection:blog limit="3" sort="date:desc" }}
                <div
                    class="md:w-6/12 lg:w-4/12 xl:w-4/12 w-full flex-none px-[calc(0.5*_1.5rem)] max-w-full sm:max-md:!mb-8 xsm:max-sm:!mb-6">
                    <div id="bp-1-1" class="blog-post wow fadeInUp">
                        <!-- BLOG POST IMAGE -->
                        <div class="blog-post-img !mb-[35px] aspect-[4/3] overflow-hidden rounded-[16px]">
                            {{ if featured_image }}
                            <img class="img-fluid w-full h-full object-cover transition-transform duration-500 hover:scale-110 decor-line"
                                src="{{ featured_image }}" alt="{{ title }}" loading="lazy"
                                onerror="this.onerror=null;this.src='/images/no_image_placeholder.png';" />
                            {{ else }}
                            <img class="img-fluid w-full h-full object-cover decor-line"
                                src="/images/no_image_placeholder.png" alt="{{ title }}" loading="lazy" />
                            {{ /if }}
                        </div>
                        <!-- BLOG POST TEXT -->
                        <div class="blog-post-txt">
                            <h2
                                class="s-20 w--700 xl:!text-[1.25rem] lg:max-xl:!text-[1.18755rem] md:max-lg:!text-[1.397058rem] sm:max-md:!text-[1.4375rem] xsm:max-sm:!text-[1.3125rem] !font-bold xl:!mb-[15px] lg:max-xl:!mb-[12px] md:max-lg:!mb-[12px] sm:max-md:!mb-[18px] xsm:max-sm:!mb-[14px] leading-[1.35] font-Jakarta sm:max-md:!leading-[1.4] xsm:max-sm:!leading-[1.4]">
                                <a class="text-[#353f4f] hover:!underline" href="{{ url }}">{{ title }}</a>
                            </h2>
                            <!-- Post Meta -->
                            <div class="blog-post-meta mt-[20px]">
                                <ul class="post-meta-list ico-10">
                                    <li class="w-auto inline-block align-top clear-none">
                                        <p
                                            class="p-sm w--500 font-medium text-[#353f4f] leading-none !mb-0 xsm:max-sm:!mb-0">
                                            {{ author:name }}
                                        </p>
                                    </li>
                                    <li
                                        class="meta-list-divider w-auto inline-block align-top clear-none relative -rotate-90 px-px py-0 top-0 lg:max-xl:px-px lg:max-xl:py-0 md:max-lg:px-px md:max-lg:py-0">
                                        <p class="text-[#353f4f] leading-none !mb-0 xsm:max-sm:!mb-0">
                                            <span class="flaticon-minus"></span>
                                        </p>
                                    </li>
                                    <li class="w-auto inline-block align-top clear-none">
                                        <p class="p-sm text-[#353f4f] leading-none !mb-0 xsm:max-sm:!mb-0">
                                            {{ date }}
                                        </p>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        <!-- END BLOG POST TEXT -->
                    </div>
                </div>
                {{ /collection:blog }}
            </div>
            <!-- End row -->
        </div>

        <div class="img-block-btn !text-center wow fadeInUp !mt-10">
            {{ cta }}
            <!-- Button -->
            <a href="{{ link }}" class="btn !rounded-[4px] btn--theme hover--tra-black">{{ text }}</a>
            {{ /cta }}
        </div>
        <!-- End container -->
    </section>
    <!-- END BLOG-1 -->
    {{ /blog_section }}

    <!-- BANNER-1
                ============================================= -->

    <section id="banner-1" class="pt--100 pt-[100px] lg:max-xl:pt-[80px] md:max-lg:pt-[70px] banner-section mb-15">
        <div class="container">
            <!-- BANNER-1 WRAPPER -->
            <div
                class="banner-1-wrapper rounded-[16px] relative overflow-hidden !text-center sm:max-md:mr-[-15px] sm:max-md:ml-[-15px] sm:max-md:my-0 sm:max-md:rounded-[0_0] xsm:max-sm:mr-[-15px] xsm:max-sm:ml-[-15px] xsm:max-sm:my-0 xsm:max-sm:rounded-[0_0]">
                <div
                    class="cta-box banner-overlay bg-[url('/images/bg-05.jpg')] bg--fixed pt-[75px] !pb-[85px] px-[15%] lg:max-xl:pt-[60px] lg:max-xl:!pb-[70px] lg:max-xl:px-[15%] md:max-lg:pt-[45px] md:max-lg:!pb-[55px] md:max-lg:px-[12%] sm:max-md:pt-[55px] sm:max-md:!pb-[65px] sm:max-md:px-[60px] xsm:max-sm:pt-[60px] xsm:max-sm:!pb-[70px] xsm:max-sm:px-[30px] bg-scroll sm:max-md:w-auto xsm:max-sm:w-auto w-full bg-no-repeat bg-[center_center] bg-cover">
                    <div class="flex flex-wrap mx-[calc(-0.5*_1.5rem)]">
                        <!-- BANNER-1 TEXT -->
                        <div class="flex-none w-full max-w-full px-[calc(0.5*_1.5rem)]">
                            <div class="banner-1-txt color--white">
                                <!-- Title -->
                                <h2
                                    class="s-45 w--700 xl:!text-[2.8125rem] lg:max-xl:!text-[2.5625rem] md:max-lg:!text-[2.20588rem] sm:max-md:!text-[2.25rem] xsm:max-sm:!text-[1.8125rem] !font-bold !tracking-[-0.5px] xl:!mb-[25px] lg:max-xl:!mb-[16px] md:max-lg:!mb-[16px] sm:max-md:!mb-[12px] xsm:max-sm:!mb-[12px] leading-[1.25] font-Jakarta sm:max-md:!leading-[1.35] xsm:max-sm:!leading-[1.35]">
                                    {{ cta_large_box:headline }}
                                </h2>
                                <!-- Text -->
                                <p
                                    class="p-xl !mt-0 !mb-[25px] lg:max-xl:!mt-[15px] md:max-lg:!mt-3 sm:max-md:!mt-[14px] xsm:max-sm:!text-[1.125rem] xsm:max-sm:!mt-[14px] lg:max-xl:!mb-[25px] md:max-lg:!mb-[20px] sm:max-md:!mb-[20px] xsm:max-sm:!mb-[20px]">
                                    {{ cta_large_box:text }}
                                </p>
                                <div class="btns-group inline-block">
                                    <!-- Button -->
                                    <a href="/nous-contacter-devis-photoboth-borne-miroir"
                                        class="btn !rounded-[4px] btn--theme hover--tra-white mr-2">Réservez
                                    </a>
                                    <a href="/contacter"
                                        class="btn !rounded-[4px] btn--tra-white hover--theme hover--tra-white">Contactez-nous
                                    </a>
                                </div>
                            </div>
                        </div>
                        <!-- END BANNER-1 TEXT -->
                    </div>
                    <!-- End row -->
                </div>
                <!-- End banner overlay -->
            </div>
            <!-- END BANNER-1 WRAPPER -->
        </div>
        <!-- End container -->
    </section>
    <!-- END BANNER-1 -->

    <!-- DIVIDER LINE -->
    <hr
        class="divider w-full h-px bg-transparent bg-[linear-gradient(90deg,rgba(206,211,246,0)_0,#bbb_38%,#bbb_64%,rgba(206,211,246,0)_99%)] opacity-40 !m-0 ![border:none]" />

    {{ partial:modal }}
</div>