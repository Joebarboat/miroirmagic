                            <!-- Image -->
                            <div
                                class="fbox-img !mb-0 gr--whitesmoke h--195 xl:!m-[0_8px_30px] xl:!pt-[42px] lg:max-xl:!mt-0 lg:max-xl:!mb-[50px] lg:max-xl:mx-0 lg:max-xl:pt-[35px] md:max-lg:!mt-0 md:max-lg:!mb-[45px] md:max-lg:mx-0 md:max-lg:pt-[30px] sm:max-md:!mt-0 sm:max-md:!mb-[50px] sm:max-md:mx-[10%] sm:max-md:pt-[46px] xsm:max-sm:!mt-0 xsm:max-sm:!mb-[50px] xsm:max-sm:mx-3 xsm:max-sm:pt-[40px] rounded-[12px_12px_0_0]">
                                <div class="aspect-[3/4] w-full">
                                    {{ partial:partials/image_fallback }}
                                </div>

                            </div>
                            <!-- Text -->
                            <div class="fbox-txt">
                                <h2
                                    class="s-22 w--700 xl:!text-[1.375rem] lg:max-xl:!text-[1.25rem] md:max-lg:!text-[1.397058rem] sm:max-md:!text-[1.4375rem] xsm:max-sm:!text-[1.3125rem] xl:!leading-[1.35] font-Jakarta sm:max-md:!leading-[1.4] xsm:max-sm:!leading-[1.4] !font-bold !mt-5 !mb-[15px]">
                                    {{ headline}}
                                </h2>
                                <p class="!mb-0">{{ text }}</p>
                            </div>
                        </div>
                    </div>
                    <!-- END FEATURE BOX #3 -->
                    {{ /block_3 }}
                </div>
                <!-- End row -->
            </div>
            <!-- END FEATURES-2 WRAPPER -->

            <!-- ACTION BUTTON -->
            <div class="flex flex-wrap mx-[calc(-0.5*_1.5rem)] pb-0 mt-[60px]">
                <div class="flex-none w-full max-w-full px-[calc(0.5*_1.5rem)]">
                    <div class="img-block-btn !text-center wow fadeInUp !mt-0">
