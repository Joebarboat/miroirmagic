<!-- PAGE CONTENT
                      ============================================= -->
<div id="page" class="page font--jakarta">
    <section id="hero-5"
        class="bg--scroll hero-section relative md:max-lg:!mt-[40px] z-[3] pt-[140px] !pb-[50px] lg:max-xl:pt-[130px] lg:max-xl:!pb-[50px] md:max-lg:pt-[50px] md:max-lg:!pb-[50px] sm:max-md:!mb-[50px] xsm:max-sm:!mb-[50px] w-full bg-no-repeat bg-[center_center] bg-cover bg-fixed sm:max-md:w-auto sm:max-md:bg-scroll xsm:max-sm:w-auto xsm:max-sm:bg-scroll">
        <div class="container">
            <div class="flex flex-wrap mx-[calc(-0.5*_1.5rem)] items-center">
                <!-- HERO TEXT -->
                <div
                    class="xl:w-6/12 lg:max-xl:w-6/12 md:max-lg:w-6/12 w-full flex-none px-[calc(0.5*_1.5rem)] max-w-full">
                    <div class="hero-5-txt">
                        <!-- Title -->
                        <h1
                            class="hero-headline text-white s-58 !mb-[20px] w--700 xl:!text-[3.625rem] lg:max-xl:!text-[3.375rem] md:max-lg:!text-[3.08823rem] sm:max-md:!text-[2.5rem] xsm:max-sm:!text-[2.0625rem] !font-bold leading-[1.3] xl:!mb-[25px] lg:max-xl:!mb-[20px] md:max-lg:!mb-[20px] xsm:max-sm:!mb-[15px] font-Jakarta">
                            {{ hero_headline }}
                        </h1>
                        <!-- Text -->
                        <p
                            class="text-white p-lg mb--30 xl:!mb-[30px] pr-[10%] lg:max-xl:!mb-[25px] lg:max-xl:pr-[10%] md:max-lg:!mb-[25px] md:max-lg:pr-0 xsm:max-sm:!mb-[20px]">
                            {{ hero_text }}
                        </p>
                        <!-- Button -->
                        <div class="flex flex-wrap items-start">
                            <a href="/tarifs" class="btn !rounded-[4px] btn--theme hover--theme mr-2 !mb-2">Voir Les
                                Tarifs</a>
                            <a href="/nous-contacter-devis-photoboth-borne-miroir"
                                class="btn !rounded-[4px] btn--theme hover--theme">J'aimerais une offre</a>
                        </div>
                    </div>
                </div>
                <!-- END HERO TEXT -->
                <!-- HERO IMAGE -->
                <div
                    class="xl:w-6/12 lg:max-xl:w-6/12 md:max-lg:w-6/12 w-full flex-none px-[calc(0.5*_1.5rem)] max-w-full">
                    <div class="hero-5-img">
                        <img class="img-fluid rounded-xl max-h-[650px] shadow-2xl hero-image object-cover object-center mx-auto block"
                            src="/images/hero/hero-main.webp"
                            srcset="/images/hero/hero-main.webp 360w, /images/hero/hero-main.webp 460w"
                            sizes="(max-width: 600px) 100vw, 600px" width="600" height="900" fetchpriority="high"
                            alt="Location Photobooth Miroir Magic" />
                    </div>
                </div>
            </div>
            <!-- End row -->
        </div>
        <!-- End container -->
        <!-- WAVE SHAPE BOTTOM -->
        <div class="wave-shape-bottom !absolute w-full left-0 bottom-0">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 170">
                <path fill-opacity="1"
                    d="M0,160L120,160C240,160,480,160,720,138.7C960,117,1200,75,1320,53.3L1440,32L1440,320L1320,320C1200,320,960,320,720,320C480,320,240,320,120,320L0,320Z">
                </path>
            </svg>
        </div>
    </section>
    <!-- END HERO-5 -->

    <!-- TEXT CONTENT
                         ============================================= -->
    {{ intro_section }}
    <section
        class="py-[40px] pt-0 md:pb-[120px] md:pt-[140px] lg:max-xl:pt-[70px] md:max-lg:pt-[70px] ct-02 content-section division">
        <div class="container">
            <!-- SECTION CONTENT (ROW) -->
            <div class="flex flex-wrap mx-[calc(-0.5*_1.5rem)] items-center">
                <!-- IMAGE BLOCK -->
                <div
                    class="order-1 mt-8 md:order-0 md:mt-0 xl:w-6/12 lg:max-xl:w-6/12 md:max-lg:w-6/12 w-full flex-none px-[calc(0.5*_1.5rem)] max-w-full">
                    <div
                        class="img-block !text-center left-column wow fadeInRight mr-[30px] lg:max-xl:mr-[5px] md:max-lg:mr-0 sm:max-md:mx-[3%] xsm:max-sm:m-[0_2%_35px]">
                        <div class="aspect-[3/4] w-full">
                            <img src="{{ image:url }}"
                                class="w-full h-full object-cover rounded-xl shadow-xl decor-line" loading="lazy"
                                alt="{{ headline }}" />
                        </div>

                    </div>
                </div>
                <!-- TEXT BLOCK -->
                <div
                    class="xl:w-6/12 lg:max-xl:w-6/12 md:max-lg:w-6/12 w-full flex-none px-[calc(0.5*_1.5rem)] max-w-full">
                    <div class="txt-block right-column wow fadeInLeft">
                        <!-- Title -->
                        <h2
                            class="s-46 w--700 xl:!text-[2.875rem] lg:max-xl:!text-[2.625rem] md:max-lg:!text-[2.35294rem] sm:max-md:!text-[2.25rem] xsm:max-sm:!text-[1.8125rem] !font-bold lg:max-xl:!mb-[20px] md:max-lg:!mb-[15px] sm:max-md:!mb-[20px] xsm:max-sm:!mb-[15px] xl:!mb-[26px] leading-[1.25] font-Jakarta sm:max-md:!leading-[1.35] xsm:max-sm:!leading-[1.35]">
                            {{ headline }}
                        </h2>
                        <div class="txt-block">{{ text }}</div>
                        <!-- Link -->
                        <div class="txt-block-tra-link mt-[25px]">
                            <a href="{{ cta_link }}" class="btn !rounded-[4px] btn--theme hover--theme mr-2">{{ cta_text
                                }}</a>
                        </div>
                    </div>
                </div>
                <!-- END TEXT BLOCK -->
            </div>
            <!-- END SECTION CONTENT (ROW) -->
        </div>
        <!-- End container -->
    </section>
    <!-- END TEXT CONTENT -->
    {{ /intro_section }}

    <!-- FEATURES-11
                         ============================================= -->
    {{ features_section }}
    <section
        class="pt--100 pb-[60px] pt-[100px] lg:max-xl:pt-[80px] md:max-lg:pt-[70px] features-section division main-features-section">
        <div class="container">
            <div class="flex flex-wrap mx-[calc(-0.5*_1.5rem)] justify-center">
                <div class="md:w-10/12 lg:max-xl:w-9/12 xl:w-9/12 w-full flex-none px-[calc(0.5*_1.5rem)] max-w-full">
                </div>
            </div>

            <div class="fbox-wrapper">
                <div class="mx-[calc(-0.5*_1.5rem)] row-cols-1 row-cols-md-2 rows-3">
                    <div
                        class="section-title mb--70 xl:!mb-[70px] lg:max-xl:!mb-[60px] md:max-lg:!mb-[50px] text-center !md:text-left">
                        <h2
                            class="s-50 w--700 xl:!text-[3.125rem] lg:max-xl:!text-[2.875rem] md:max-lg:!text-[2.64705rem] sm:max-md:!text-[2.375rem] xsm:max-sm:!text-[2.0625rem] !font-bold !tracking-[-0.5px] leading-[1.25] font-Jakarta sm:max-md:!leading-[1.35] xsm:max-sm:!leading-[1.35] !text-white">
                            {{ headline }}
                        </h2>
                    </div>

                    <div class="w-full px-[calc(0.5*_1.5rem)] pb-5 gap-4 flex flex-col justify-start items-start">
                        {{ features_list }}
                        <div
                            class="feature-badge px-6 py-3 rounded-[50px] inline-flex items-center border border-white border-1 xl:!text-[1.375rem] lg:max-xl:!text-[1.25rem] md:max-lg:!text-[1.397058rem] sm:max-md:!text-[1.4375rem] xsm:max-sm:!text-[1.3125rem] text-white xl:!mb-[10px] lg:max-xl:!mb-[12px] md:max-lg:!mb-[12px] xsm:max-sm:!mb-[15px] leading-[1.35] font-Jakarta sm:max-md:!leading-[1.4] xsm:max-sm:!leading-[1.4] wow fadeInLeft">
                            <svg class="w-5 h-5 mr-2" xmlns="http://www.w3.org/2000/svg" xml:space="preserve"
                                style="enable-background: new 0 0 400 297.9" viewBox="0 0 400 297.9">
                                <path d="m33.3 166.7 96.4 96.4h0c2 2 5.3 2 7.3 0h0L366.7 33.3" style="
                                        fill: none;
                                        stroke: #fff;
                                        stroke-width: 66.6667;
                                        stroke-linecap: round;
                                        stroke-linejoin: round;
                                        stroke-miterlimit: 133.3333;
                                    " />
                            </svg>
                            <span>{{ value }}</span>
                        </div>
                        {{ /features_list }}
                    </div>
                </div>
                <!-- End row -->
            </div>
        </div>
    </section>
    <!-- END FEATURES-11 -->
    {{ /features_section }}

    <!-- BOX CONTENT
                         ============================================= -->

    <!-- SECTION VIDÉO PLEINE LARGEUR -->
    <section class="py-0">
        <div class="video-section-wrapper" style="position: relative; width: 100%; background: #000;">
            <div class="video-container" style="position: relative; width: 100%; padding-bottom: 56.25%; height: 0;">
                <!-- Image poster -->
                <img src="/images/video_cover.webp" alt="Miroir Magic Photobooth - Vidéo de présentation"
                    class="video-poster" id="videoPoster"
                    style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 2; cursor: pointer;"
                    loading="lazy" />

                <!-- Overlay avec bouton play -->
                <div class="play-button-overlay" id="playOverlay"
                    style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; z-index: 3; background: rgba(0, 0, 0, 0.3); cursor: pointer;">
                    <div class="play-button-gold" id="playButton" aria-label="Lire la vidéo"></div>
                </div>

                <!-- Container pour l'iframe -->
                <div id="videoIframeContainer" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;">
                </div>

                <!-- Bouton de fermeture (caché par défaut) -->
                <button id="closeVideoBtn"
                    style="position: absolute; top: 15px; right: 15px; background: rgba(0,0,0,0.7); color: white; border: none; border-radius: 50%; width: 40px; height: 40px; font-size: 24px; cursor: pointer; z-index: 5; display: none; line-height: 1;">×</button>
            </div>
        </div>
    </section>

    <style>
        .play-button-gold {
            position: relative;
            width: 100px;
            height: 100px;
            background: linear-gradient(-140deg,
                    rgba(150, 106, 31, 1) 0%,
                    rgba(228, 195, 100, 1) 42%,
                    rgba(202, 150, 29, 1) 74%,
                    rgba(207, 184, 132, 1) 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 8px 24px rgba(228, 195, 100, 0.4);
            border: 3px solid rgba(255, 255, 255, 0.3);
            animation: pulse-gold 2s infinite;
        }

        .play-button-gold::before {
            content: '';
            position: absolute;
            width: 0;
            height: 0;
            border-style: solid;
            border-width: 15px 0 15px 26px;
            border-color: transparent transparent transparent #fff;
            margin-left: 4px;
        }

        .play-button-gold:hover {
            transform: scale(1.1);
            box-shadow: 0 12px 32px rgba(228, 195, 100, 0.6);
            animation: none;
        }

        @keyframes pulse-gold {
            0% {
                box-shadow: 0 8px 24px rgba(228, 195, 100, 0.4);
            }

            50% {
                box-shadow: 0 8px 24px rgba(228, 195, 100, 0.7),
                    0 0 0 20px rgba(228, 195, 100, 0.1);
            }

            100% {
                box-shadow: 0 8px 24px rgba(228, 195, 100, 0.4);
            }
        }

        .play-button-overlay:hover {
            background: rgba(0, 0, 0, 0.4) !important;
        }

        #closeVideoBtn:hover {
            background: rgba(228, 195, 100, 0.9) !important;
            transform: scale(1.1);
        }

        @media (max-width: 768px) {
            .play-button-gold {
                width: 80px;
                height: 80px;
            }

            .play-button-gold::before {
                border-width: 12px 0 12px 20px;
            }

            #closeVideoBtn {
                top: 10px;
                right: 10px;
                width: 35px;
                height: 35px;
                font-size: 20px;
            }
        }

        @media (max-width: 480px) {
            .play-button-gold {
                width: 70px;
                height: 70px;
            }

            .play-button-gold::before {
                border-width: 10px 0 10px 17px;
            }
        }
    </style>
    <script>
        // Attendre que le DOM soit chargé
        document.addEventListener('DOMContentLoaded', function () {
            // Vérifier si la section vidéo existe
            const videoSection = document.querySelector('.video-section-wrapper');
            if (!videoSection) return;

            // Extraire l'ID YouTube
            let videoUrl = '{{ video_sew:video_url }}';
            if (!videoUrl || videoUrl.trim() === '') {
                videoUrl = 'https://www.youtube.com/watch?v=6jduVHjNPTA';
            }
            const videoId = videoUrl.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/)?.[1];

            if (!videoId) {
                console.error('ID vidéo YouTube invalide');
                return;
            }

            // Eléments DOM
            const playOverlay = document.getElementById('playOverlay');
            const playButton = document.getElementById('playButton');
            const videoPoster = document.getElementById('videoPoster');
            const videoContainer = document.getElementById('videoIframeContainer');
            const closeBtn = document.getElementById('closeVideoBtn');

            if (!playOverlay || !playButton || !videoPoster || !videoContainer || !closeBtn) {
                console.warn('Certains éléments vidéo sont manquants dans le DOM');
                return;
            }

            // Variables d'état
            let player = null;
            let isPlaying = false;

            // Fonction pour charger et jouer la vidéo
            function loadAndPlayVideo() {
                // Si la vidéo est déjà en cours, ne rien faire
                if (isPlaying) return;

                // Masquer l'overlay et le poster
                playOverlay.style.display = 'none';
                videoPoster.style.display = 'none';

                // Afficher le bouton de fermeture
                closeBtn.style.display = 'block';

                // Créer l'iframe YouTube
                const iframe = document.createElement('iframe');
                iframe.id = 'youtubeIframe';
                iframe.style.cssText = 'position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0; z-index: 4;';
                iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1&playsinline=1&enablejsapi=1`;
                iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
                iframe.allowFullscreen = true;
                iframe.loading = 'lazy';

                // Ajouter l'iframe au container
                videoContainer.appendChild(iframe);

                // Mettre à jour l'état
                isPlaying = true;

                // Initialiser l'API YouTube
                if (typeof YT !== 'undefined' && YT.Player) {
                    initializePlayer();
                } else {
                    // Charger l'API YouTube
                    const tag = document.createElement('script');
                    tag.src = "https://www.youtube.com/iframe_api";
                    const firstScriptTag = document.getElementsByTagName('script')[0];
                    firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

                    window.onYouTubeIframeAPIReady = initializePlayer;
                }
            }

            // Initialiser le lecteur YouTube
            function initializePlayer() {
                player = new YT.Player('youtubeIframe', {
                    events: {
                        'onReady': onPlayerReady,
                        'onStateChange': onPlayerStateChange
                    }
                });
            }

            // Quand le lecteur est prêt
            function onPlayerReady(event) {
                // La vidéo démarre automatiquement avec autoplay=1
            }

            // Surveiller les changements d'état
            function onPlayerStateChange(event) {
                // État 1 = lecture, État 2 = pause
                if (event.data === YT.PlayerState.PLAYING) {
                    isPlaying = true;
                } else if (event.data === YT.PlayerState.PAUSED) {
                    isPlaying = false;
                } else if (event.data === YT.PlayerState.ENDED) {
                    isPlaying = false;
                    // Réinitialiser à la fin de la vidéo
                    resetVideo();
                }
            }

            // Fonction pour arrêter et réinitialiser la vidéo
            function stopAndResetVideo() {
                if (player) {
                    player.stopVideo();
                    player.destroy();
                    player = null;
                }

                // Supprimer l'iframe
                const iframe = document.getElementById('youtubeIframe');
                if (iframe) {
                    iframe.remove();
                }

                // Réafficher l'overlay et le poster
                playOverlay.style.display = 'flex';
                videoPoster.style.display = 'block';

                // Masquer le bouton de fermeture
                closeBtn.style.display = 'none';

                // Réinitialiser l'état
                isPlaying = false;
            }

            // Réinitialiser la vidéo (sans supprimer l'iframe)
            function resetVideo() {
                if (player) {
                    player.seekTo(0);
                    player.pauseVideo();
                }

                // Réafficher l'overlay et le poster
                playOverlay.style.display = 'flex';
                videoPoster.style.display = 'block';

                // Masquer le bouton de fermeture
                closeBtn.style.display = 'none';

                // Réinitialiser l'état
                isPlaying = false;
            }

            // Ajouter les événements
            playButton.addEventListener('click', function (e) {
                e.stopPropagation();
                loadAndPlayVideo();
            });

            playOverlay.addEventListener('click', function (e) {
                e.stopPropagation();
                loadAndPlayVideo();
            });

            // Cliquer sur le poster lance aussi la vidéo
            videoPoster.addEventListener('click', function (e) {
                e.stopPropagation();
                loadAndPlayVideo();
            });

            // Bouton de fermeture
            closeBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                stopAndResetVideo();
            });

            // Option: Mettre en pause en cliquant sur la vidéo
            document.addEventListener('click', function (e) {
                if (isPlaying && player && e.target.closest('#videoIframeContainer')) {
                    // Basculer entre pause et play
                    if (player.getPlayerState() === YT.PlayerState.PLAYING) {
                        player.pauseVideo();
                    } else {
                        player.playVideo();
                    }
                }
            });

            // Préchargement YouTube
            playButton.addEventListener('mouseenter', function () {
                if (!isPlaying) {
                    const link = document.createElement('link');
                    link.rel = 'preconnect';
                    link.href = 'https://www.youtube.com';
                    document.head.appendChild(link);
                }
            }, { once: true });
        });
    </script>

    <!-- FEATURES-2
                         ============================================= -->

    {{ event_section }}
    <section id="features-2"
        class="py--100 py-[100px] lg:max-xl:py-[80px] md:max-lg:py-[70px] features-section division">
