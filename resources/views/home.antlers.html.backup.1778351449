                </div>
            </div>
            <!-- FEATURES-2 WRAPPER  -->
            <div class="fbox-wrapper !text-center">
                <div class="flex flex-wrap mx-[calc(-0.5*_1.5rem)] row-cols-1 row-cols-md-3">
                    <!-- FEATURE BOX #1 -->
                    {{ block_1}}
                    <div class="md:w-4/12 lg:w-4/12 xl:w-4/12 flex-none w-full max-w-full px-[calc(0.5*_1.5rem)]">
